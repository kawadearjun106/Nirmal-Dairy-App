<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌙 Base App Theme -->
    <style name="Base.Theme.NirmalApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dairy Blue Palette -->
        <item name="colorPrimary">#2196F3</item>
        <item name="colorPrimaryContainer">#1976D2</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#03DAC5</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Status bar + nav bar -->
        <item name="android:statusBarColor">?attr/colorPrimaryContainer</item>
        <item name="android:navigationBarColor">?attr/colorPrimary</item>

        <!-- Use Material toolbar colors -->
        <item name="android:colorBackground">#FFFFFF</item>
        <item name="android:textColor">#000000</item>
    </style>

    <!-- 🌞 Active App Theme -->
    <style name="Theme.NirmalApp" parent="Base.Theme.NirmalApp" />

    <!-- 🧾 Card Style (Admin Dashboard) -->
    <style name="AdminCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:padding">14dp</item>
    </style>

    <!-- 📝 Text Style for Admin Cards -->
    <style name="AdminCardText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

</resources>
